# Basic Auth for OAuth Token Endpoint (client_id:client_password base64 encoded)
# Format: Basic <base64(client_id:client_password)>
# Example: If client_id=myapp and client_password=secret123
#          Then encode "myapp:secret123" to base64 = "bXlhcHA6c2VjcmV0MTIz"
#          Final value: Basic bXlhcHA6c2VjcmV0MTIz
WAFFY_OAUTH_CLIENT_AUTH=Basic your-base64-encoded-client-credentials

